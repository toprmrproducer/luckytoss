---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const withBase = (path: string) => {
	const trimmed = path.replace(/^\/+/, '');
	return trimmed ? `${base}/${trimmed}` : `${base}/`;
};
const canonical = new URL(withBase(canonicalPath), Astro.site).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen antialiased">
		<header class="border-b border-[#eae4d6] bg-white/85 backdrop-blur">
			<nav class="mx-auto flex max-w-[820px] items-center justify-between px-6 py-5">
				<a
					href={withBase('/')}
					class="font-[Sora] text-xl font-extrabold tracking-tight text-[#221b10]"
				>
					Lucky<span class="text-[#c9982e]">Toss</span>
				</a>
				<div class="hidden items-center gap-7 text-[15px] font-semibold text-[#4a4234] sm:flex">
					<a href={withBase('/')} class="transition hover:text-[#b8860b]">Roll</a>
					<a href={withBase('/faq')} class="transition hover:text-[#b8860b]">FAQ</a>
					<a href={withBase('/about')} class="transition hover:text-[#b8860b]">About</a>
				</div>
			</nav>
		</header>

		{/* Top leaderboard ad slot — reserved, invisible until a real <ins> is dropped in */}
		<div class="ad-slot ad-leaderboard mx-auto px-6 pt-6" data-ad-slot="leaderboard" style="max-width:970px;min-height:0">
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		{/*
			Three-column shell: left skyscraper gutter | 820px content | right skyscraper gutter.
			Skyscrapers only render >=1280px (xl); below that the content column stays centered
			and the gutters collapse. All ad slots are empty + invisible until populated.
		*/}
		<div class="mx-auto flex w-full max-w-[1360px] items-start justify-center gap-8 px-4">
			<aside class="ad-slot hidden w-[160px] shrink-0 xl:block" data-ad-slot="skyscraper-left" style="position:sticky;top:120px;min-height:0">
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>

			<main class="mx-auto w-full max-w-[820px] px-6 pt-24 pb-28">
				<slot />
			</main>

			<aside class="ad-slot hidden w-[160px] shrink-0 xl:block" data-ad-slot="skyscraper-right" style="position:sticky;top:120px;min-height:0">
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>
		</div>

		{/* Bottom in-article ad slot — reserved, invisible until populated */}
		<div class="ad-slot ad-in-article mx-auto px-6 pb-6" data-ad-slot="in-article" style="max-width:728px;min-height:0">
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		<footer class="mt-10 border-t border-[#eae4d6] bg-[#faf8f3]">
			<div class="mx-auto max-w-[820px] px-6 py-12 text-[15px] text-[#4a4234]">
				<p class="max-w-2xl">
					Every roll and flip happens locally in your browser using
					Math.random() &mdash; nothing you do here is ever sent to a server.
				</p>
				<div class="mt-5 flex flex-wrap gap-6 font-semibold">
					<a href={withBase('/about')} class="transition hover:text-[#b8860b]">About</a>
					<a href={withBase('/privacy')} class="transition hover:text-[#b8860b]">Privacy Policy</a>
					<a href={withBase('/faq')} class="transition hover:text-[#b8860b]">FAQ</a>
				</div>
				<p class="mt-5 text-[#8a7e68]">&copy; {year} LuckyToss</p>
			</div>
		</footer>

		<style is:global>
			/* Ad slots reserve layout space but show nothing until a real ad
			   is dropped in. Empty placeholder boxes can hurt AdSense approval,
			   so an unfilled slot has no border, no label, and no height. Once a
			   real <ins>/<iframe> is dropped in, it defines its own size. */
			.ad-slot {
				min-height: 0;
			}
			.ad-slot:empty {
				min-height: 0;
				border: 0;
			}
		</style>
	</body>
</html>
