---
import Layout from '../layouts/Layout.astro';

const faqs = [
	{
		q: 'Is LuckyToss really free?',
		a: 'Yes. Every roll and flip runs on your own device, so there is no server cost per use and no reason to charge or limit usage.',
	},
	{
		q: 'Is the randomness actually fair?',
		a: "Yes. LuckyToss uses the browser's built-in Math.random() for the coin flip and every dice roll, giving each outcome an equal, unbiased chance.",
	},
	{
		q: 'What dice can I roll?',
		a: 'You can roll 1 to 6 standard six-sided dice, or switch to Custom Dice to roll polyhedral tabletop dice (d4, d6, d8, d10, d12, d20) in any quantity with an optional plus or minus modifier, shown in classic notation like 3d8+2.',
	},
	{
		q: 'Is any of my data saved or uploaded?',
		a: 'No. Everything — flips, rolls, streaks, and history — happens locally in your browser tab. Nothing is sent to a server, and it all resets when you refresh.',
	},
	{
		q: 'What happens on a hot streak?',
		a: 'Land a streak of 3 or more of the same coin result, roll all 6s on standard dice, or roll the natural maximum on your polyhedral set, and LuckyToss celebrates with a short confetti animation.',
	},
	{
		q: 'Is there anything to do while I wait?',
		a: 'Yes. There is a built-in game of Snake tucked below the tools if you want a quick distraction between rolls.',
	},
];
---

<Layout
	title="FAQ — LuckyToss"
	description="Frequently asked questions about LuckyToss's free, private, browser-based coin flip, dice roller, and polyhedral dice tool."
	canonicalPath="/faq"
>
	<div class="mx-auto max-w-2xl">
		<h1 class="font-[Sora] text-3xl font-extrabold tracking-tight text-[#221b10] sm:text-4xl">
			Frequently Asked Questions
		</h1>
		<div class="mt-8 space-y-5">
			{
				faqs.map((item) => (
					<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-6">
						<h2 class="font-[Sora] text-lg font-bold text-[#221b10]">{item.q}</h2>
						<p class="mt-2 text-[#4a4234]">{item.a}</p>
					</div>
				))
			}
		</div>
	</div>
</Layout>
