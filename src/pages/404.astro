---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
---

<Layout
	title="Page Not Found — LuckyToss"
	description="This page could not be found."
	canonicalPath="/404"
>
	<div class="py-20 text-center">
		<p class="font-[Sora] text-6xl font-extrabold text-[#c9982e]">404</p>
		<h1 class="mt-4 font-[Sora] text-3xl font-extrabold text-[#221b10]">Page not found</h1>
		<p class="mt-4 text-[#4a4234]">
			That page doesn't exist.
			<a href={base} class="font-semibold text-[#c9982e] underline underline-offset-4 hover:text-[#b8860b]">Back to the homepage</a>.
		</p>
	</div>
</Layout>
